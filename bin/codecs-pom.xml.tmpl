<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0">
  <modelVersion>4.0.0</modelVersion>

  <!--
    Inheriting pdfbox-parent pulls in its jbig2.version/jai.version
    properties, so jbig2-imageio and jai-imageio below resolve to the exact
    versions that this PDFBox release was built and tested against, instead
    of whatever happens to be "latest" on Maven Central.
  -->
  <parent>
    <groupId>org.apache.pdfbox</groupId>
    <artifactId>pdfbox-parent</artifactId>
    <version>@PDFBOX_VERSION@</version>
  </parent>

  <groupId>aquarion.pdfbox</groupId>
  <artifactId>codec-resolver</artifactId>
  <version>1.0.0</version>
  <packaging>pom</packaging>

  <properties>
    <!-- PDFBox has no dependency on TwelveMonkeys, so there's no upstream
         version to inherit here; bump deliberately when needed. -->
    <twelvemonkeys.version>3.12.0</twelvemonkeys.version>
  </properties>

  <dependencies>
    <dependency>
      <groupId>org.apache.pdfbox</groupId>
      <artifactId>jbig2-imageio</artifactId>
      <version>${jbig2.version}</version>
    </dependency>
    <dependency>
      <groupId>com.github.jai-imageio</groupId>
      <artifactId>jai-imageio-core</artifactId>
      <version>${jai.version}</version>
    </dependency>
    <dependency>
      <groupId>com.github.jai-imageio</groupId>
      <artifactId>jai-imageio-jpeg2000</artifactId>
      <version>${jai.version}</version>
    </dependency>
    <dependency>
      <groupId>com.twelvemonkeys.imageio</groupId>
      <artifactId>imageio-jpeg</artifactId>
      <version>${twelvemonkeys.version}</version>
    </dependency>
  </dependencies>
</project>
