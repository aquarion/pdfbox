<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0">
  <modelVersion>4.0.0</modelVersion>

  <!--
    Inheriting pdfbox-parent pulls in its jbig2.version property, so
    jbig2-imageio resolves to the exact version that this PDFBox release was
    built and tested against, instead of whatever happens to be "latest" on
    Maven Central.

    jai-imageio is excluded: the signing subkey used for the only release
    (1.4.0) was subsequently revoked by the author, so its PGP signature can
    no longer be trusted. See https://github.com/aquarion/pdfbox/issues/2
  -->
  <parent>
    <groupId>org.apache.pdfbox</groupId>
    <artifactId>pdfbox-parent</artifactId>
    <version>@PDFBOX_VERSION@</version>
  </parent>

  <groupId>aquarion.pdfbox</groupId>
  <artifactId>codec-resolver</artifactId>
  <version>1.0.0</version>
  <packaging>pom</packaging>

  <properties>
    <!-- PDFBox has no dependency on TwelveMonkeys, so there's no upstream
         version to inherit here; bump deliberately when needed. -->
    <twelvemonkeys.version>3.13.1</twelvemonkeys.version>
  </properties>

  <dependencies>
    <dependency>
      <groupId>org.apache.pdfbox</groupId>
      <artifactId>jbig2-imageio</artifactId>
      <version>${jbig2.version}</version>
    </dependency>
    <dependency>
      <groupId>com.twelvemonkeys.imageio</groupId>
      <artifactId>imageio-jpeg</artifactId>
      <version>${twelvemonkeys.version}</version>
    </dependency>
    <dependency>
      <groupId>com.twelvemonkeys.imageio</groupId>
      <artifactId>imageio-tiff</artifactId>
      <version>${twelvemonkeys.version}</version>
    </dependency>
    <dependency>
      <groupId>com.twelvemonkeys.imageio</groupId>
      <artifactId>imageio-webp</artifactId>
      <version>${twelvemonkeys.version}</version>
    </dependency>
  </dependencies>
</project>
